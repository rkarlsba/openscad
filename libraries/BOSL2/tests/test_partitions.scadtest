[[test]]
name = "test_half_of"
script = '''
include <../std.scad>

module test_half_of() {
    // half_of applied to a path: keep only points in the specified half
    sq = square(10, center=true);
    // Keep back half (y>0)
    top = half_of(sq, v=BACK);
    assert(is_path(top) || is_region(top));
    for (p = (is_region(top) ? flatten(top) : top))
        assert(p.y >= -0.001);
}
test_half_of();
'''

[[test]]
name = "test_left_half"
script = '''
include <../std.scad>

module test_left_half() {
    sq = square(10, center=true);
    h = left_half(sq);
    assert(is_path(h) || is_region(h));
    for (p = (is_region(h) ? flatten(h) : h))
        assert(p.x <= 0.001);
}
test_left_half();
'''

